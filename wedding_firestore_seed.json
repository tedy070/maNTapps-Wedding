{
  "_info": {
    "app": "maNTapps Wedding — Budgeting Pernikahan",
    "versi": "2.0",
    "database": "Firebase Firestore",
    "dibuat": "2026-04-22",
    "petunjuk": [
      "1. Buka Firebase Console → Firestore Database",
      "2. Buat collection 'weddings'",
      "3. Buat document dengan ID = UID pengguna (lihat Authentication → Users)",
      "4. Di dalam document tersebut, buat sub-collection sesuai struktur di bawah",
      "5. Data di bawah adalah data contoh / seed awal"
    ],
    "struktur_path": "weddings/{uid}/{koleksi}/{docId}"
  },

  "_security_rules": {
    "keterangan": "Paste rules ini ke Firestore → Rules → Publish",
    "rules": "rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    match /weddings/{userId}/{document=**} {\n      allow read, write: if request.auth != null\n                         && request.auth.uid == userId;\n    }\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}"
  },

  "_catatan_multi_app": {
    "info": "Jika maNTapPos dan maNTapps Wedding pakai Firebase project yang SAMA, gabungkan rules-nya:",
    "rules_gabungan": "rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    match /stores/{userId}/{document=**} {\n      allow read, write: if request.auth != null && request.auth.uid == userId;\n    }\n    match /weddings/{userId}/{document=**} {\n      allow read, write: if request.auth != null && request.auth.uid == userId;\n    }\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}"
  },

